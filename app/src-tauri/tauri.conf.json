{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ant's",
  "version": "6.0.0",
  "identifier": "digital.ants.superorganism",
  "build": {
    "frontendDist": "../../web",
    "devUrl": "http://localhost:8765"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Superorganismo Digital Transparente",
    "longDescription": "Ant's — uma colônia de bots que administra o seu dispositivo. App nativo que sobe o backend local e abre a interface viva.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/ants_backend"],
    "resources": []
  }
}
